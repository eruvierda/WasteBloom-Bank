<!-- Sidebar (Desktop) -->
<aside
    class="fixed inset-y-0 left-0 z-50 w-64 bg-white dark:bg-dark-sidebar shadow-lg transform -translate-x-full lg:translate-x-0 transition-transform duration-300 ease-in-out"
    id="sidebar">
    <div class="flex items-center justify-between h-16 px-6 border-b border-slate-100 dark:border-slate-700">
        <span class="text-xl font-bold text-primary flex items-center gap-2">
            <span class="material-icons-round">recycling</span> Bank Sampah
        </span>
        <button class="lg:hidden text-slate-500 hover:text-primary" onclick="toggleSidebar()">
            <span class="material-icons-round">close</span>
        </button>
    </div>

    <nav class="p-4 space-y-1 overflow-y-auto max-h-[calc(100vh-4rem)]">
        <div class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2 mt-4 px-2">Menu Utama</div>

        <% if (user && user.role==='admin' ) { %>
            <a href="/admin/dashboard"
                class="flex items-center gap-3 px-4 py-3 rounded-xl transition-colors <%= path === '/admin/dashboard' ? 'bg-primary text-white shadow-soft' : 'text-slate-600 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-700' %>">
                <span class="material-icons-round">dashboard</span>
                <span class="font-medium">Dashboard</span>
            </a>
            <a href="/admin/users"
                class="flex items-center gap-3 px-4 py-3 rounded-xl transition-colors <%= path === '/admin/users' ? 'bg-primary text-white shadow-soft' : 'text-slate-600 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-700' %>">
                <span class="material-icons-round">people</span>
                <span class="font-medium">Kelola Pengguna</span>
            </a>
            <a href="/admin/waste-types"
                class="flex items-center gap-3 px-4 py-3 rounded-xl transition-colors <%= path === '/admin/waste-types' ? 'bg-primary text-white shadow-soft' : 'text-slate-600 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-700' %>">
                <span class="material-icons-round">delete_outline</span>
                <span class="font-medium">Jenis Sampah</span>
            </a>
            <a href="/admin/transactions"
                class="flex items-center gap-3 px-4 py-3 rounded-xl transition-colors <%= path === '/admin/transactions' ? 'bg-primary text-white shadow-soft' : 'text-slate-600 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-700' %>">
                <span class="material-icons-round">receipt_long</span>
                <span class="font-medium">Transaksi</span>
            </a>
            <a href="/admin/withdrawals"
                class="flex items-center gap-3 px-4 py-3 rounded-xl transition-colors <%= path === '/admin/withdrawals' ? 'bg-primary text-white shadow-soft' : 'text-slate-600 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-700' %>">
                <span class="material-icons-round">payments</span>
                <span class="font-medium">Penarikan</span>
            </a>
            <% } else { %>
                <a href="/dashboard"
                    class="flex items-center gap-3 px-4 py-3 rounded-xl transition-colors <%= path === '/dashboard' ? 'bg-primary text-white shadow-soft' : 'text-slate-600 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-700' %>">
                    <span class="material-icons-round">speed</span>
                    <span class="font-medium">Dashboard</span>
                </a>
                <a href="/deposit"
                    class="flex items-center gap-3 px-4 py-3 rounded-xl transition-colors <%= path === '/deposit' ? 'bg-primary text-white shadow-soft' : 'text-slate-600 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-700' %>">
                    <span class="material-icons-round">recycling</span>
                    <span class="font-medium">Setor Sampah</span>
                </a>
                <a href="/transactions"
                    class="flex items-center gap-3 px-4 py-3 rounded-xl transition-colors <%= path === '/transactions' ? 'bg-primary text-white shadow-soft' : 'text-slate-600 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-700' %>">
                    <span class="material-icons-round">history</span>
                    <span class="font-medium">Riwayat</span>
                </a>
                <a href="/withdraw"
                    class="flex items-center gap-3 px-4 py-3 rounded-xl transition-colors <%= path === '/withdraw' ? 'bg-primary text-white shadow-soft' : 'text-slate-600 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-700' %>">
                    <span class="material-icons-round">account_balance_wallet</span>
                    <span class="font-medium">Tarik Saldo</span>
                </a>
                <% } %>

                    <div class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2 mt-6 px-2">Akun</div>
                    <a href="/profile"
                        class="flex items-center gap-3 px-4 py-3 rounded-xl transition-colors <%= path === '/profile' ? 'bg-primary text-white shadow-soft' : 'text-slate-600 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-700' %>">
                        <span class="material-icons-round">person</span>
                        <span class="font-medium">Profil Saya</span>
                    </a>
                    <a href="/logout"
                        class="flex items-center gap-3 px-4 py-3 rounded-xl text-danger hover:bg-danger/10 transition-colors mt-auto">
                        <span class="material-icons-round">logout</span>
                        <span class="font-medium">Keluar</span>
                    </a>
    </nav>
</aside>

<!-- Overlay for mobile sidebar -->
<div id="sidebar-overlay" class="fixed inset-0 bg-black/50 z-40 hidden lg:hidden" onclick="toggleSidebar()"></div>
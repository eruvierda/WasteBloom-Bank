<header
    class="h-16 bg-white dark:bg-dark-sidebar border-b border-slate-100 dark:border-slate-700 sticky top-0 z-30 px-4 lg:px-8 flex items-center justify-between shadow-sm">
    <div class="flex items-center gap-4">
        <button class="lg:hidden p-2 text-slate-600 hover:bg-slate-100 rounded-full" onclick="toggleSidebar()">
            <span class="material-icons-round">menu</span>
        </button>
        <h1 class="text-lg font-bold text-slate-800 dark:text-white lg:hidden">Bank Sampah</h1>
    </div>

    <div class="flex items-center gap-4">
        <div class="text-right hidden sm:block">
            <p class="text-xs text-slate-500 font-medium">Selamat Datang,</p>
            <p class="text-sm font-bold text-slate-800 dark:text-white">
                <%= user ? user.name : 'Guest' %>
            </p>
        </div>
        <div
            class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary font-bold border-2 border-primary">
            <%= user ? user.name.charAt(0).toUpperCase() : 'G' %>
        </div>
    </div>
</header>
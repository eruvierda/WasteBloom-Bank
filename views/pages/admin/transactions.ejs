<%- include('../../partials/head') %>

    <div class="flex min-h-screen bg-background-light dark:bg-background-dark">
        <%- include('../../partials/sidebar') %>

            <div class="flex-1 flex flex-col min-h-screen lg:ml-64 transition-all duration-300">
                <%- include('../../partials/navbar') %>

                    <main class="flex-1 p-6 space-y-6 pb-24 lg:pb-8">
                        <div class="flex items-center justify-between">
                            <h1 class="text-2xl font-bold text-slate-800 dark:text-white">Semua Transaksi</h1>
                            <div class="flex gap-2">
                                <a href="/admin/transactions?status=pending"
                                    class="px-4 py-2 bg-warning text-white text-sm font-medium rounded-lg hover:bg-yellow-600 transition-colors">Pending</a>
                                <a href="/admin/transactions"
                                    class="px-4 py-2 bg-slate-200 text-slate-700 text-sm font-medium rounded-lg hover:bg-slate-300 transition-colors dark:bg-slate-700 dark:text-slate-200 dark:hover:bg-slate-600">All</a>
                            </div>
                        </div>

                        <div
                            class="bg-white dark:bg-dark-sidebar rounded-2xl shadow-soft border border-slate-100 dark:border-slate-700 overflow-hidden">
                            <div class="overflow-x-auto">
                                <table class="w-full text-sm text-left text-slate-500 dark:text-slate-400">
                                    <thead
                                        class="text-xs text-slate-700 uppercase bg-slate-50 dark:bg-slate-800 dark:text-slate-400">
                                        <tr>
                                            <th scope="col" class="px-6 py-4">ID</th>
                                            <th scope="col" class="px-6 py-4">User</th>
                                            <th scope="col" class="px-6 py-4">Tanggal</th>
                                            <th scope="col" class="px-6 py-4">Jenis</th>
                                            <th scope="col" class="px-6 py-4">Berat</th>
                                            <th scope="col" class="px-6 py-4">Total</th>
                                            <th scope="col" class="px-6 py-4">Status</th>
                                            <th scope="col" class="px-6 py-4 text-right">Aksi</th>
                                        </tr>
                                    </thead>
                                    <tbody class="divide-y divide-slate-100 dark:divide-slate-700">
                                        <% transactions.forEach(txn=> { %>
                                            <tr
                                                class="bg-white border-b dark:bg-dark-sidebar dark:border-slate-700 hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors">
                                                <td class="px-6 py-4 font-medium text-slate-900 dark:text-white">#<%=
                                                        txn.id %>
                                                </td>
                                                <td class="px-6 py-4 font-semibold text-slate-800 dark:text-white">
                                                    <%= txn.user_name %>
                                                </td>
                                                <td class="px-6 py-4">
                                                    <%= new Date(txn.created_at).toLocaleDateString() %>
                                                </td>
                                                <td class="px-6 py-4">
                                                    <%= txn.waste_name %>
                                                </td>
                                                <td class="px-6 py-4">
                                                    <%= txn.weight %>
                                                        <%= txn.unit %>
                                                </td>
                                                <td class="px-6 py-4 font-bold text-primary">Rp <%=
                                                        txn.total_amount.toLocaleString('id-ID') %>
                                                </td>
                                                <td class="px-6 py-4">
                                                    <span
                                                        class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium 
                                            <%= txn.status === 'pending' ? 'bg-warning/10 text-warning' : 
                                               txn.status === 'approved' ? 'bg-success/10 text-success' : 'bg-danger/10 text-danger' %>">
                                                        <%= txn.status.charAt(0).toUpperCase() + txn.status.slice(1) %>
                                                    </span>
                                                </td>
                                                <td class="px-6 py-4 text-right flex justify-end gap-2">
                                                    <% if (txn.status==='pending' ) { %>
                                                        <button type="button"
                                                            onclick="editTransaction('<%= txn.id %>', '<%= txn.weight %>')"
                                                            class="text-blue-600 hover:text-blue-900 dark:text-blue-400 dark:hover:text-blue-300 mr-2"
                                                            title="Edit">
                                                            <span class="material-icons-round">edit</span>
                                                        </button>
                                                        <form action="/admin/transactions/approve" method="POST"
                                                            class="inline">
                                                            <input type="hidden" name="id" value="<%= txn.id %>">
                                                            <button type="submit"
                                                                class="text-green-600 hover:text-green-900 dark:text-green-400 dark:hover:text-green-300"
                                                                title="Approve">
                                                                <span class="material-icons-round">check_circle</span>
                                                            </button>
                                                        </form>
                                                        <form action="/admin/transactions/reject" method="POST"
                                                            class="inline">
                                                            <input type="hidden" name="id" value="<%= txn.id %>">
                                                            <button type="submit"
                                                                class="text-red-600 hover:text-red-900 dark:text-red-400 dark:hover:text-red-300 ml-1"
                                                                title="Reject">
                                                                <span class="material-icons-round">cancel</span>
                                                            </button>
                                                        </form>
                                                        <% } else { %>
                                                            <span class="text-slate-400">-</span>
                                                            <% } %>
                                                </td>
                                            </tr>
                                            <% }) %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </main>
                    <%- include('../../partials/bottom-nav') %>
            </div>
    </div>

    <!-- Edit Transaction Modal -->
    <div id="editTxnModal" class="hidden fixed inset-0 z-50 overflow-y-auto" aria-labelledby="modal-title" role="dialog"
        aria-modal="true">
        <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
            <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" aria-hidden="true"
                onclick="toggleEditModal()"></div>
            <span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>
            <div
                class="inline-block align-bottom bg-white dark:bg-slate-800 rounded-lg text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg w-full">
                <form action="/admin/transactions/edit" method="POST" id="editTxnForm">
                    <input type="hidden" name="id" id="editTxnId">
                    <div class="bg-white dark:bg-slate-800 px-4 pt-5 pb-4 sm:p-6 sm:pb-4">
                        <h3 class="text-lg leading-6 font-medium text-slate-900 dark:text-white mb-4">Edit Transaksi
                        </h3>
                        <div>
                            <label for="editWeight"
                                class="block text-sm font-medium text-slate-700 dark:text-slate-300">Berat Baru
                                (kg)</label>
                            <input type="number" step="0.1" name="weight" id="editWeight" required
                                class="mt-1 block w-full rounded-md border-slate-300 shadow-sm focus:border-primary focus:ring focus:ring-primary/20 bg-slate-50 dark:bg-slate-700 dark:border-slate-600 dark:text-white sm:text-sm p-2">
                            <p class="mt-2 text-xs text-slate-500 text-slate-400">Total harga akan dikalkulasi ulang
                                otomatis.</p>
                        </div>
                    </div>
                    <div class="bg-gray-50 dark:bg-slate-700/50 px-4 py-3 sm:px-6 sm:flex sm:flex-row-reverse">
                        <button type="submit"
                            class="w-full inline-flex justify-center rounded-md border border-transparent shadow-sm px-4 py-2 bg-primary text-base font-medium text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary sm:ml-3 sm:w-auto sm:text-sm">
                            Simpan
                        </button>
                        <button type="button" onclick="toggleEditModal()"
                            class="mt-3 w-full inline-flex justify-center rounded-md border border-gray-300 shadow-sm px-4 py-2 bg-white text-base font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 sm:mt-0 sm:ml-3 sm:w-auto sm:text-sm dark:bg-slate-800 dark:text-slate-300 dark:border-slate-600 dark:hover:bg-slate-700">
                            Batal
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        function toggleEditModal() {
            document.getElementById('editTxnModal').classList.toggle('hidden');
        }

        function editTransaction(id, weight) {
            document.getElementById('editTxnId').value = id;
            document.getElementById('editWeight').value = weight;
            toggleEditModal();
        }
    </script>

    <%- include('../../partials/footer') %>
<%- include('../../partials/head') %>

    <div class="flex min-h-screen bg-background-light dark:bg-background-dark">
        <%- include('../../partials/sidebar') %>

            <div class="flex-1 flex flex-col min-h-screen lg:ml-64 transition-all duration-300">
                <%- include('../../partials/navbar') %>

                    <main class="flex-1 p-6 space-y-6 pb-24 lg:pb-8">
                        <div class="flex items-center justify-between">
                            <h1 class="text-2xl font-bold text-slate-800 dark:text-white">Manajemen Pengguna</h1>
                            <!-- Search or Filter could go here -->
                        </div>

                        <div
                            class="bg-white dark:bg-dark-sidebar rounded-2xl shadow-soft border border-slate-100 dark:border-slate-700 overflow-hidden">
                            <div class="overflow-x-auto">
                                <table class="w-full text-sm text-left text-slate-500 dark:text-slate-400">
                                    <thead
                                        class="text-xs text-slate-700 uppercase bg-slate-50 dark:bg-slate-800 dark:text-slate-400">
                                        <tr>
                                            <th scope="col" class="px-6 py-4">ID</th>
                                            <th scope="col" class="px-6 py-4">Nama</th>
                                            <th scope="col" class="px-6 py-4">Email</th>
                                            <th scope="col" class="px-6 py-4">Telepon</th>
                                            <th scope="col" class="px-6 py-4">Saldo</th>
                                            <th scope="col" class="px-6 py-4">Role</th>
                                            <th scope="col" class="px-6 py-4">Bergabung</th>
                                            <th scope="col" class="px-6 py-4 text-right">Aksi</th>
                                        </tr>
                                    </thead>
                                    <tbody class="divide-y divide-slate-100 dark:divide-slate-700">
                                        <% users.forEach(user=> { %>
                                            <tr
                                                class="bg-white border-b dark:bg-dark-sidebar dark:border-slate-700 hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors">
                                                <td class="px-6 py-4 font-medium text-slate-900 dark:text-white">#<%=
                                                        user.id %>
                                                </td>
                                                <td class="px-6 py-4">
                                                    <div class="flex items-center gap-3">
                                                        <div
                                                            class="w-8 h-8 rounded-full bg-slate-100 dark:bg-slate-700 flex items-center justify-center text-slate-500">
                                                            <span class="material-icons-round text-sm">person</span>
                                                        </div>
                                                        <a href="/admin/users/<%= user.id %>"
                                                            class="font-medium text-slate-900 dark:text-white hover:text-primary transition-colors">
                                                            <%= user.name %>
                                                        </a>
                                                    </div>
                                                </td>
                                                <td class="px-6 py-4">
                                                    <%= user.email %>
                                                </td>
                                                <td class="px-6 py-4">
                                                    <%= user.phone || '-' %>
                                                </td>
                                                <td class="px-6 py-4 font-bold text-primary">Rp <%=
                                                        user.balance.toLocaleString('id-ID') %>
                                                </td>
                                                <td class="px-6 py-4">
                                                    <span
                                                        class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= user.role === 'admin' ? 'bg-purple-100 text-purple-800 dark:bg-purple-900 dark:text-purple-300' : 'bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-300' %>">
                                                        <%= user.role.charAt(0).toUpperCase() + user.role.slice(1) %>
                                                    </span>
                                                </td>
                                                <td class="px-6 py-4">
                                                    <%= new Date(user.created_at).toLocaleDateString() %>
                                                </td>
                                                <td class="px-6 py-4 text-right">
                                                    <a href="/admin/users/<%= user.id %>"
                                                        class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-slate-100 text-slate-500 hover:bg-primary hover:text-white transition-colors"
                                                        title="View Details">
                                                        <span class="material-icons-round text-sm">visibility</span>
                                                    </a>
                                                </td>
                                            </tr>
                                            <% }) %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </main>
                    <%- include('../../partials/bottom-nav') %>
            </div>
    </div>

    <%- include('../../partials/footer') %>
<%- include('../partials/head') %>

    <div class="flex min-h-screen bg-background-light dark:bg-background-dark">
        <%- include('../partials/sidebar') %>

            <div class="flex-1 flex flex-col min-h-screen lg:ml-64 transition-all duration-300">
                <%- include('../partials/navbar') %>

                    <main class="flex-1 p-6 space-y-6 pb-24 lg:pb-8">
                        <div class="flex items-center justify-between">
                            <h1 class="text-2xl font-bold text-slate-800 dark:text-white">Tarik Saldo</h1>
                            <nav class="hidden sm:flex" aria-label="Breadcrumb">
                                <ol class="inline-flex items-center space-x-1 md:space-x-3">
                                    <li class="inline-flex items-center">
                                        <a href="/dashboard"
                                            class="inline-flex items-center text-sm font-medium text-slate-700 hover:text-primary dark:text-slate-400 dark:hover:text-white">
                                            <span class="material-icons-round text-base mr-1">home</span>
                                            Home
                                        </a>
                                    </li>
                                    <li>
                                        <div class="flex items-center">
                                            <span
                                                class="material-icons-round text-slate-400 text-base">chevron_right</span>
                                            <span
                                                class="ml-1 text-sm font-medium text-slate-500 md:ml-2 dark:text-slate-400">Tarik
                                                Saldo</span>
                                        </div>
                                    </li>
                                </ol>
                            </nav>
                        </div>

                        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                            <!-- Withdraw Form -->
                            <div class="space-y-6">
                                <div
                                    class="bg-white dark:bg-dark-sidebar rounded-2xl shadow-soft p-6 border border-slate-100 dark:border-slate-700">
                                    <h2 class="text-lg font-bold text-slate-800 dark:text-white mb-2">Form Penarikan
                                    </h2>
                                    <div
                                        class="bg-primary/5 p-4 rounded-xl mb-6 flex justify-between items-center border border-primary/10">
                                        <div>
                                            <p class="text-xs text-slate-500 uppercase font-bold tracking-wider">Saldo
                                                Tersedia</p>
                                            <p class="text-2xl font-bold text-primary">Rp <%=
                                                    user.balance.toLocaleString('id-ID') %>
                                            </p>
                                        </div>
                                        <span
                                            class="material-icons-round text-primary/30 text-4xl">account_balance_wallet</span>
                                    </div>

                                    <% if (typeof error !=='undefined' && error) { %>
                                        <div
                                            class="bg-red-50 text-red-500 text-sm p-3 rounded-lg border border-red-100 flex items-center gap-2 mb-4">
                                            <span class="material-icons-round text-base">error_outline</span>
                                            <%= error %>
                                        </div>
                                        <% } %>
                                            <% if (typeof success !=='undefined' && success) { %>
                                                <div
                                                    class="bg-green-50 text-green-600 text-sm p-3 rounded-lg border border-green-100 flex items-center gap-2 mb-4">
                                                    <span
                                                        class="material-icons-round text-base">check_circle_outline</span>
                                                    <%= success %>
                                                </div>
                                                <% } %>

                                                    <form action="/withdraw" method="POST" class="space-y-4">
                                                        <div>
                                                            <label
                                                                class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1"
                                                                for="amount">Jumlah Penarikan (Rp)</label>
                                                            <input type="number" min="10000" step="5000" id="amount"
                                                                name="amount"
                                                                class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-3 text-sm focus:ring-primary focus:border-primary block"
                                                                placeholder="Min. 10.000" required>
                                                        </div>

                                                        <div>
                                                            <label
                                                                class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1"
                                                                for="bank_name">Nama Bank / E-Wallet</label>
                                                            <select id="bank_name" name="bank_name"
                                                                class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-3 text-sm focus:ring-primary focus:border-primary block"
                                                                required>
                                                                <option value="" disabled selected>Pilih Bank...
                                                                </option>
                                                                <option value="BCA">BCA</option>
                                                                <option value="BRI">BRI</option>
                                                                <option value="BNI">BNI</option>
                                                                <option value="Mandiri">Mandiri</option>
                                                                <option value="Gopay">GoPay</option>
                                                                <option value="OVO">OVO</option>
                                                                <option value="Dana">DANA</option>
                                                            </select>
                                                        </div>

                                                        <div>
                                                            <label
                                                                class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1"
                                                                for="account_number">Nomor Rekening</label>
                                                            <input type="number" id="account_number"
                                                                name="account_number"
                                                                class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-3 text-sm focus:ring-primary focus:border-primary block"
                                                                placeholder="Contoh: 1234567890" required>
                                                        </div>

                                                        <div>
                                                            <label
                                                                class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1"
                                                                for="account_holder">Nama Pemilik Rekening</label>
                                                            <input type="text" id="account_holder" name="account_holder"
                                                                class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-3 text-sm focus:ring-primary focus:border-primary block"
                                                                placeholder="Sesuai buku tabungan" required>
                                                        </div>

                                                        <button type="submit"
                                                            class="w-full py-3.5 bg-primary hover:bg-blue-600 text-white font-semibold rounded-xl shadow-lg shadow-primary/30 transition-all flex items-center justify-center gap-2">
                                                            <span class="material-icons-round">send</span>
                                                            Ajukan Penarikan
                                                        </button>
                                                    </form>
                                </div>
                            </div>

                            <!-- Withdrawal History -->
                            <div class="space-y-6">
                                <h2 class="text-lg font-bold text-slate-800 dark:text-white mb-2">Riwayat Penarikan</h2>
                                <div
                                    class="bg-white dark:bg-dark-sidebar rounded-2xl shadow-soft border border-slate-100 dark:border-slate-700 divide-y divide-slate-100 dark:divide-slate-700 max-h-[600px] overflow-y-auto">
                                    <% if (withdrawals && withdrawals.length> 0) { %>
                                        <% withdrawals.forEach(wd=> { %>
                                            <div class="p-4 flex items-center justify-between">
                                                <div class="flex items-center gap-4">
                                                    <div
                                                        class="w-10 h-10 rounded-full bg-blue-50 dark:bg-blue-900/20 text-blue-600 flex items-center justify-center">
                                                        <span class="material-icons-round">account_balance</span>
                                                    </div>
                                                    <div>
                                                        <h4
                                                            class="text-sm font-semibold text-slate-900 dark:text-white">
                                                            <%= wd.bank_name %> - <%= wd.account_number %>
                                                        </h4>
                                                        <p class="text-xs text-slate-500 dark:text-slate-400">
                                                            <%= new Date(wd.created_at).toLocaleDateString() %>
                                                        </p>
                                                    </div>
                                                </div>
                                                <div class="text-right">
                                                    <p class="text-sm font-bold text-slate-800 dark:text-white">Rp <%=
                                                            wd.amount.toLocaleString('id-ID') %>
                                                    </p>
                                                    <span
                                                        class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-medium 
                                            <%= wd.status === 'pending' ? 'bg-warning/10 text-warning' : 
                                               wd.status === 'approved' ? 'bg-success/10 text-success' : 'bg-danger/10 text-danger' %> mt-1">
                                                        <%= wd.status.charAt(0).toUpperCase() + wd.status.slice(1) %>
                                                    </span>
                                                </div>
                                            </div>
                                            <% }) %>
                                                <% } else { %>
                                                    <div class="p-8 text-center text-slate-500 dark:text-slate-400">
                                                        Belum ada riwayat penarikan.
                                                    </div>
                                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </main>
                    <%- include('../partials/bottom-nav') %>
            </div>
    </div>

    <%- include('../partials/footer') %>